# DeepSeek API Key (get from https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-api-key-here

# Baidu Cloud Gesture Recognition API
# Get from https://console.bce.baidu.com/ai/#/ai/face/overview/index
# 1. Create an application → get API Key & Secret Key
# 2. Enable "手势识别" service
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key
